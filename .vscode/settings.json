{
  // ---- Formatting: Prettier owns formatting, runs on every save ----
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },

  // ---- ESLint: auto-fix lint issues on save, validate TS + TSX ----
  "editor.codeActionsOnSave": { "source.fixAll.eslint": "explicit" },
  "eslint.validate": ["typescript", "typescriptreact"],

  // ---- TypeScript: use the workspace TS version, not VS Code's bundled one ----
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "typescript.preferences.importModuleSpecifier": "non-relative",

  // ---- Inline annotations ----
  // Write `// CLAUDE: <do this>` in code, then tell Claude "apply the CLAUDE annotations".
  // Todo Tree just makes them visible in the sidebar — optional.
  "todo-tree.general.tags": ["CLAUDE", "TODO", "FIXME"],

  // ---- Noise reduction ----
  "files.exclude": {
    "**/.expo": true,
    "**/node_modules": true
  },
  "search.exclude": {
    "**/package-lock.json": true,
    "**/coverage": true
  }
}
